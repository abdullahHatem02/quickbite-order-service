# Test environment. Loaded by tests/setup-env.ts (local runs); in CI the same
# values are injected by docker-compose.test.yml. Single region (eg) — hot and
# archive shards point at two databases on the same Postgres test container.
NODE_ENV=test
PORT=4000

ACCESS_SECRET=test-access-secret
REFRESH_SECRET=test-refresh-secret
ACCESS_EXPIRES_IN=3600
REFRESH_EXPIRES_IN=604800

CORS_ORIGINS=http://localhost:3000

REGIONS=eg

DB_POOL_MAX=5
DB_MIGRATION_DIRECTORY=src/migrations
DB_MIGRATION_EXTENSION=ts

DB_eg_HOST=localhost
DB_eg_PORT=5432
DB_eg_USERNAME=postgres
DB_eg_PASSWORD=postgres
DB_eg_NAME=order_service_eg_test

ARCHIVE_DB_eg_HOST=localhost
ARCHIVE_DB_eg_PORT=5432
ARCHIVE_DB_eg_USERNAME=postgres
ARCHIVE_DB_eg_PASSWORD=postgres
ARCHIVE_DB_eg_NAME=order_service_archive_eg_test

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_URL=amqp://guest:guest@localhost:5672

CORE_SERVICE_BASE_URL=http://localhost:3000
CORE_INTERNAL_API_KEY=test

KASHIER_MERCHANT_ID=test
KASHIER_API_KEY=test
KASHIER_SECRET_KEY=test
KASHIER_RETURN_URL=http://localhost/return
KASHIER_FAIL_URL=http://localhost/fail
KASHIER_WEBHOOK_URL=http://localhost/webhook
