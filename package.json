{
  "name": "order-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate": "knex --knexfile src/lib/knex/knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile src/lib/knex/knexfile.ts migrate:rollback",
    "migrate:status": "knex --knexfile src/lib/knex/knexfile.ts migrate:status",
    "migrate:make": "knex --knexfile src/lib/knex/knexfile.ts migrate:make",
    "migrate:all": "tsx scripts/migrate-all.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
