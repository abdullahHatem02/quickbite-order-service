# Anything matched here is NOT sent to the Docker build context.
# Smaller context  =>  faster builds + smaller image layers.

# Node deps are reinstalled inside the image — don't ship the host's.
node_modules

# Compiled output is produced in the builder stage — never copy host's.
dist

# Local secrets must not bake into the image; pass them at runtime.
.env
.env.*
!.env.example

# IDE / editor cruft
.idea
.vscode
*.iml

# Git history isn't needed by the build.
.git
.gitignore

# Logs and OS junk
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# Throwaway scripts (per CLAUDE.md §5)
play

# Docker files themselves don't belong in the image
Dockerfile
.dockerignore
docker-compose.yml
docker

# Local archives
*.zip
